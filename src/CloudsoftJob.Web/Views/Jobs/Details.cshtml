@model CloudsoftJob.Core.Models.JobPosting

@{
    ViewData["Title"] = Model.Title;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="card-title">@Model.Title</h2>
                <p class="text-muted">
                    <i class="fas fa-map-marker-alt"></i> @Model.Location
                </p>
                <p>@Model.Description</p>
                <p class="text-muted mb-0">
                    <i class="fas fa-calendar"></i> Deadline: @Model.Deadline.ToString("yyyy-MM-dd")
                </p>
            </div>
            <div class="card-footer bg-transparent">
                <a class="btn btn-outline-secondary" asp-controller="Jobs" asp-action="Index">Back to Jobs</a>
            </div>
        </div>
    </div>
</div>
