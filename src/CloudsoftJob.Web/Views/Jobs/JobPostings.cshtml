@model IReadOnlyCollection<CloudsoftJob.Core.Models.JobPosting>

@{
    ViewData["Title"] = "Job Listings";
}

<h2>Job Listings</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a class="btn btn-primary" asp-controller="Jobs" asp-action="Create">
        <i class="fas fa-plus"></i> Post New Job
    </a>
</p>

@if (Model.Count == 0)
{
    <p class="lead text-muted">No job listings available.</p>
}
else
{
    <div class="row">
        @foreach (var jobPosting in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@jobPosting.Title</h5>
                        <p class="card-text text-muted">
                            <i class="fas fa-map-marker-alt"></i> @jobPosting.Location
                        </p>
                        <p class="card-text">@jobPosting.Description</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <small class="text-muted">
                            <i class="fas fa-calendar"></i> Deadline: @jobPosting.Deadline.ToString("yyyy-MM-dd")
                        </small>
                        <a class="btn btn-sm btn-outline-primary float-end" asp-controller="Jobs" asp-action="Details" asp-route-id="@jobPosting.Id">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
