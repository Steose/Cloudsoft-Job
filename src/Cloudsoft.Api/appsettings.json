{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FeatureFlags": {
    "UseMongoDb": false,
    "UseAzureStorage": false,
    "UseAzureKeyVault": false
  },
  "KeyVault": {
    "VaultUri": "",
    "ManagedIdentityClientId": ""
  },
  "MongoDb": {
    "ConnectionString": "mongodb://{username}:{password}@{hostname}:{port}",
    "DatabaseName": "Cloudsoft",
    "JobPostingsCollectionName": "jobPostings",
    "EmployersCollectionName": "employers"
  },
  "AzureBlob": {
    "ContainerUrl": "https://{accountname}.blob.core.windows.net/{container}"
  },
  "AllowedHosts": "*"
}
