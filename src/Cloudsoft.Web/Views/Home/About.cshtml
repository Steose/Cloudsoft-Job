@{
    ViewData["Title"] = "About";
    var heroImageUrl = ViewData["HeroImageUrl"] as string ?? Url.Content("~/images/hero.png");
}

<div class="hero-section" style="background-image: url('@heroImageUrl')">
    <div class="hero-content text-white">
        <h1 class="hero-title display-4">Welcome to CloudSoft-Job</h1>
        <div class="hero-text">
            <p class="lead">We are a team of passionate cloud developers dedicated to creating innovative tools for job announcements.</p>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <h2>Our Mission</h2>
            <p>
                On CloudSoft-Job platform, we strive to connect talented professionals with exciting career opportunities while providing employers with powerful tools to find the right candidates.
            </p>
        </div>
        <div class="col-md-6">
            <h2>Cloudsoft-Job App</h2>
            <p>
                The CloudSoft-Job app is a course project designed to simplify the job search and recruitment process. Whether you're a job seeker looking for your next opportunity or an employer seeking top talent, our app provides a seamless experience to meet your needs.
            </p>
        </div>
        <div class="col-md-6">
            <h2>Contact Us</h2>
            <p>
                If you have any questions, feedback, or would like to learn more about our platform, please don't hesitate to reach out to us. We value your input and are always eager to connect with our users. Email us at <a href="mailto:60steose@gafe.molndal.se">60steose@gafe.molndal.se</a>
            </p>
        </div>

    </div>
</div>
