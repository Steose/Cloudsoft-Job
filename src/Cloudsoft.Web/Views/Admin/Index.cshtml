@model IReadOnlyCollection<Cloudsoft.Core.Models.JobPosting>

@{
    ViewData["Title"] = "Admin Dashboard";
    var applications = ViewBag.Applications as IReadOnlyCollection<Cloudsoft.Core.Models.JobApplication> ?? [];
    var applicationsByJob = applications
        .GroupBy(application => application.JobPostingId)
        .ToDictionary(group => group.Key, group => group.ToList());
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div>
        <h2 class="mb-1">Admin Dashboard</h2>
        <p class="text-muted mb-0">Manage your company's job postings and review their applications.</p>
    </div>
    <a class="btn btn-primary mt-3 mt-md-0" asp-controller="Admin" asp-action="Create">
        <i class="fas fa-plus me-2"></i>Create New Job
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Count == 0)
{
    <p class="lead text-muted">Your company has not posted any jobs yet.</p>
}
else
{
    <div class="vstack gap-4">
        @foreach (var job in Model)
        {
            var jobApplications = applicationsByJob.TryGetValue(job.Id, out var matchedApplications)
                ? matchedApplications
                : [];

            <section class="border rounded bg-white p-3 shadow-sm">
                <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mb-3">
                    <div>
                        <h3 class="h5 mb-1">@job.Title</h3>
                        <div class="text-muted small">
                            @job.Location · Deadline: @job.Deadline.ToString("yyyy-MM-dd")
                        </div>
                    </div>
                    <span class="badge align-self-start @(job.IsActive ? "bg-success" : "bg-secondary")">
                        @(job.IsActive ? "Active" : "Inactive")
                    </span>
                </div>

                <h4 class="h5 mb-3">Applications</h4>

                <div class="table-responsive">
                    <table class="table table-bordered align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Job Id</th>
                            <th>Country</th>
                            <th>CV File</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (jobApplications.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-muted">No applications have been submitted.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var application in jobApplications)
                            {
                                <tr>
                                    <td>@application.FullName</td>
                                    <td>@application.Email</td>
                                    <td><code>@application.JobPostingId</code></td>
                                    <td>@application.CountryCode</td>
                                    <td>@application.CvFileName</td>
                                </tr>
                            }
                        }
                    </tbody>
                    </table>
                </div>
            </section>
        }
    </div>
}
