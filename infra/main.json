    },
    "imageBlobContainerNameOutput": {
      "type": "string",
      "value": "[parameters('imageBlobContainerName')]"
    },
    "imageBlobContainerUrl": {
      "type": "string",
      "value": "[format('https://{0}.blob.{1}/{2}', parameters('imageStorageAccountName'), environment().suffixes.storage, parameters('imageBlobContainerName'))]"
    }
  }
}