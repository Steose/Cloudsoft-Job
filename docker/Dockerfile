FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY Cloudsoft.sln .
COPY Directory.Build.props .
COPY src/Cloudsoft.Core/Cloudsoft.Core.csproj src/Cloudsoft.Core/
COPY src/Cloudsoft.Web/Cloudsoft.Web.csproj src/Cloudsoft.Web/
RUN dotnet restore src/Cloudsoft.Web/Cloudsoft.Web.csproj

COPY . .
RUN dotnet publish src/Cloudsoft.Web/Cloudsoft.Web.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .
EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080
ENTRYPOINT ["dotnet", "Cloudsoft.Web.dll"]
