      "type": "text",
      "x": 1137.2456887961944,
      "y": 804.0965532520304,
      "width": 333.2421875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aa",
      "roundness": null,
      "seed": 188417651,
      "version": 303,
      "versionNonce": 103873245,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777383339559,
      "link": null,
      "locked": false,
      "text": "1. The employer opens `/Account/Login`.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. The employer opens `/Account/Login`.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qyCi2uRni5aF0_39m8aNi",
      "type": "text",
      "x": 1098.3980325461944,
      "y": 839.0965532520304,
      "width": 410.9375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ab",
      "roundness": null,
      "seed": 515182141,
      "version": 303,
      "versionNonce": 795318077,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777383339559,
      "link": null,
      "locked": false,
      "text": "2. The login form renders with `LoginViewModel`.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. The login form renders with `LoginViewModel`.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dkrJhF1tYL84XVvdLN3Os",
      "type": "text",
      "x": 1120.0142434836944,
      "y": 874.0965532520304,
      "width": 367.705078125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ac",
      "roundness": null,
      "seed": 496484371,
      "version": 303,
      "versionNonce": 1145808797,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777383339559,
      "link": null,
      "locked": false,
      "text": "3. The employer submits email and password.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. The employer submits email and password.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "0RCRY0tu6l7T9h3tL6bgj",
      "type": "text",
      "x": 957.3238137961943,
      "y": 909.0965532520304,
      "width": 693.0859375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ad",
      "roundness": null,
      "seed": 2027044509,
