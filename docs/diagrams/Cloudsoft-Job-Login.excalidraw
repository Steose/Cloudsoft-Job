      "versionNonce": 1460579325,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777383339559,
      "link": null,
      "locked": false,
      "text": "4. `EmployerAuthenticationService.ValidateCredentialsAsync(...)` checks the account.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4. `EmployerAuthenticationService.ValidateCredentialsAsync(...)` checks the account.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "lNLPas9QafanyKGt0lB_U",
      "type": "text",
      "x": 1079.7701028586944,
      "y": 944.0965532520304,
      "width": 448.193359375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ae",
      "roundness": null,
      "seed": 1668040115,
      "version": 303,
      "versionNonce": 934421597,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777383339559,
      "link": null,
      "locked": false,
      "text": "5. `SignInEmployerAsync(...)` creates employer claims.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "5. `SignInEmployerAsync(...)` creates employer claims.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "0aEELtd6eENPROYZx6g1t",
      "type": "text",
      "x": 1088.3687356711944,
      "y": 979.0965532520304,
      "width": 430.99609375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "af",
      "roundness": null,
      "seed": 212493053,
      "version": 303,
      "versionNonce": 973574333,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777383339559,
      "link": null,
      "locked": false,
      "text": "6. `SignInAsync(...)` writes the authentication cookie.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
